APP_NAME=高校思政课 AI 智能教学辅助平台
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
# 本地开发使用 SQLite；服务器可切换为：
# DATABASE_URL=mysql+pymysql://ai_teaching:密码@127.0.0.1:3306/ai_teaching?charset=utf8mb4
DATABASE_URL=sqlite:///./data/app.db
CORS_ORIGINS=["http://localhost:5173"]
LOG_LEVEL=INFO
JWT_SECRET_KEY=please-change-this-development-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# 首次启动时可选创建管理员；创建后建议清空 BOOTSTRAP_ADMIN_PASSWORD
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-this-admin-password

# AI 配置：本地开发可保留模拟模式，不消耗模型额度
AI_MOCK_MODE=true
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# 也兼容 OPENAI_API_KEY / OPENAI_BASE_URL / OPENAI_MODEL 命名
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=60

# RAG / Embedding；mock 模式可离线验证，也可切换 dashscope 或 openai_compatible
# DashScope 纯文本 RAG 推荐使用 text-embedding-v4（默认 1024 维）
EMBEDDING_PROVIDER=mock
# 使用阿里云百炼时改为：
# EMBEDDING_PROVIDER=dashscope
# DASHSCOPE_API_KEY=sk-...
# DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
# OpenAI 兼容接口可复用 OPENAI_API_KEY
CHROMA_PERSIST_DIRECTORY=../knowledge_base/chroma
KNOWLEDGE_UPLOAD_DIRECTORY=../knowledge_base/uploads
RAG_COLLECTION_NAME=ideology_course_kb
# 新索引验证通过后再把 RAG_ACTIVE_COLLECTION 指向版本化集合
RAG_ACTIVE_COLLECTION=
RAG_TOP_K=4
RAG_SCORE_THRESHOLD=0.15
TEXT_CHUNK_SIZE=800
TEXT_CHUNK_OVERLAP=120
MAX_UPLOAD_SIZE_MB=100
# 中央材料批量网址任务：单批上限与服务器并发批次数
MATERIAL_BATCH_MAX_ITEMS=500
MATERIAL_BATCH_WORKER_CONCURRENCY=2
