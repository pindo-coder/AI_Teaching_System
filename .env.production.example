# 复制为 .env.production，并务必修改所有密码和密钥
JWT_SECRET_KEY=replace-with-a-long-random-secret
# 服务器 MySQL 示例：mysql+pymysql://ai_teaching:密码@127.0.0.1:3306/ai_teaching?charset=utf8mb4
DATABASE_URL=sqlite:///./data/app.db
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-admin-password

# 默认保持模拟模式即可验证流程；接入真实 API 后改为 false
AI_MOCK_MODE=true
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

EMBEDDING_PROVIDER=mock
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
RAG_ACTIVE_COLLECTION=
MAX_UPLOAD_SIZE_MB=100
MATERIAL_BATCH_MAX_ITEMS=500
MATERIAL_BATCH_WORKER_CONCURRENCY=2
